# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# ---------- 虚拟环境 ----------
.venv/
venv/
env/

# ---------- IDE ----------
.idea/
.vscode/
*.swp
*.swo
*~

# ---------- 实验输出（日志、推理结果） ----------
experiments/*/test/
experiments/*/infer/

# ---------- Wandb ----------
wandb/

# ---------- 数据集（体积大，不入仓库） ----------
data/datasets/
data/DIV2K/

# ---------- OS ----------
.DS_Store
Thumbs.db

# ---------- uv / pip ----------
uv.lock
